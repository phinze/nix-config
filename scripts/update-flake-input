#!/usr/bin/env bash
set -euo pipefail

# Update a flake input and commit with version info
# Usage: update-flake-input [-y] <input-name>
#
# Always commits when there's an update (the old interactive [y/N] prompt is
# gone). A leading -y is still accepted for muscle memory but is now a no-op.

if [[ "${1:-}" == "-y" ]]; then
  shift
fi

input="${1:-}"

if [[ -z "$input" ]]; then
  echo "Usage: update-flake-input [-y] <input-name>" >&2
  echo "  -y: accepted for backwards compat; commits always happen now" >&2
  echo "Available inputs: nixvim-config, iso, double-agent, bankshot, claude-code-nix, codex-cli-nix, zen-browser" >&2
  exit 1
fi

# Systems to try when looking for package versions
systems=("aarch64-darwin" "x86_64-linux" "aarch64-linux" "x86_64-darwin")

# Get the flake URL from flake.nix
flake_url=$(grep -E "^\s*${input}\.url\s*=" flake.nix | sed 's/.*=\s*"\(.*\)";/\1/')
if [[ -z "$flake_url" ]]; then
  echo "Error: Could not find input '$input' in flake.nix" >&2
  exit 1
fi

# Convert to a fetchable URL format
# Handle git+https:// format
flake_url="${flake_url#git+}"

# Get old revision from flake.lock
old_rev=$(jq -r ".nodes[\"$input\"].locked.rev // empty" flake.lock)
if [[ -z "$old_rev" ]]; then
  echo "Error: Could not find locked revision for '$input' in flake.lock" >&2
  exit 1
fi

# Try to get version, trying multiple systems
get_version() {
  local url="$1"

  for sys in "${systems[@]}"; do
    # Try common package paths
    for pkg_path in "packages.${sys}.default.version" "packages.${sys}.${input//-/_}.version" "packages.${sys}.${input}.version"; do
      if version=$(nix eval --raw "${url}#${pkg_path}" 2>/dev/null); then
        echo "$version"
        return 0
      fi
    done

    # Special cases for known inputs
    case "$input" in
      claude-code-nix)
        if version=$(nix eval --raw "${url}#packages.${sys}.claude-code.version" 2>/dev/null); then
          echo "$version"
          return 0
        fi
        ;;
      codex-cli-nix)
        if version=$(nix eval --raw "${url}#packages.${sys}.codex.version" 2>/dev/null); then
          echo "$version"
          return 0
        fi
        ;;
    esac
  done

  echo "unknown"
}

echo "Fetching old version..."
old_version=$(get_version "${flake_url}/${old_rev}")

echo "Updating flake input '$input'..."
nix flake update "$input" 2>&1 | grep -v "^warning:" || true

# Get new revision from flake.lock
new_rev=$(jq -r ".nodes[\"$input\"].locked.rev // empty" flake.lock)

if [[ "$old_rev" == "$new_rev" ]]; then
  echo "No update available - already at latest revision"
  exit 0
fi

echo "Fetching new version..."
new_version=$(get_version "${flake_url}/${new_rev}")

# Build commit message
if [[ "$old_version" != "unknown" && "$new_version" != "unknown" ]]; then
  commit_msg="update ${input}: ${old_version} → ${new_version}"
else
  commit_msg="update ${input}"
fi

echo ""
echo "Old revision: ${old_rev:0:7}"
echo "New revision: ${new_rev:0:7}"
echo "Old version: $old_version"
echo "New version: $new_version"
echo ""
echo "Commit message: $commit_msg"
echo ""

# Print upstream changelog delta for inputs with a known changelog source
if [[ "$input" == "claude-code-nix" && "$old_version" != "unknown" && "$new_version" != "unknown" ]]; then
  if changelog=$(gh api repos/anthropics/claude-code/contents/CHANGELOG.md \
      -H "Accept: application/vnd.github.raw" 2>/dev/null); then
    delta=$(echo "$changelog" | awk -v old="$old_version" -v new="$new_version" '
      /^## / {
        if ($2 == new) { printing = 1 }
        else if ($2 == old) { printing = 0 }
      }
      printing { print }
    ')
    if [[ -n "$delta" ]]; then
      echo "Changelog:"
      echo ""
      echo "$delta"
      echo ""
    fi
  fi
fi

git add flake.lock
git commit -m "$commit_msg"
echo "Committed!"

# If we captured a changelog delta, drop into an interactive Claude session to
# review whether anything in the changelog means we should tweak our config.
# Runs *after* the commit, so the update itself is already safely landed; from
# here you can just tell Claude to go make any change it turns up.
if [[ -n "${delta:-}" ]] && command -v claude >/dev/null 2>&1; then
  echo ""
  echo "Launching Claude to review the changelog for config-relevant changes..."
  echo ""
  analysis_prompt="You are reviewing the Claude Code changelog delta below against the Claude Code configuration in this nix-config repo. Read home-manager/phinze/claude-code.nix (the source of truth for our settings.json, plugins, and hooks) and ~/.claude/settings.json (the generated result). We run yolo everywhere (--dangerously-skip-permissions with skipDangerousModePermissionPrompt=true). Identify ONLY changelog entries that are actionable for us: a setting we should add or change, a default that flipped in a way that affects us, a plugin or hook mechanism we use that changed, or a behavior shift worth knowing given how we run. Skip pure bugfixes, memory-leak fixes, and features we do not use. Be concise and lead with the verdict; if nothing is actionable, say exactly that in one line.

Changelog delta:
$delta"
  claude --dangerously-skip-permissions "$analysis_prompt"
fi
